# --- Personal Gmail / Google One (recommended): OAuth refresh token -------------
# Uploads run as YOUR account — uses your Drive storage (e.g. 2 TB Google One).
# Same Cloud project needs Google Drive API enabled.
#
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-long-refresh-token
GOOGLE_DRIVE_FOLDER_ID=paste_folder_id_from_drive_url

#
# HOW TO GET A REFRESH TOKEN (one-time setup)
#
# 1) Google Cloud Console → APIs & Services → ENABLE "Google Drive API".
# 2) OAuth consent screen → External → add yourself as Test user while in Testing,
#    or publish (stricter verification for sensitive scopes later).
# 3) Credentials → Create OAuth Client ID → type "Web application".
#    ⚠️ Two separate fields — mistakes cause "must not contain a path":
#    • Authorized JavaScript origins → leave EMPTY. (Only scheme+host here;
#      never paste .../oauthplayground — that is a path.)
#    • Authorized redirect URIs → add HERE exactly:
#        https://developers.google.com/oauthplayground
#
# 4) Open https://developers.google.com/oauthplayground/
#    Click the gear ⚙️ → ✅ "Use your own OAuth credentials"
#       → paste CLIENT_ID and CLIENT_SECRET from step 3.
#    Left column: authorize scope (paste if needed):
#      https://www.googleapis.com/auth/drive
#    Authorize APIs → Sign in → Allow.
#    "Exchange authorization code for tokens" → copy REFRESH TOKEN into .env above.
#
# 5) In Google Drive create a folder, open it, URL looks like:
#      https://drive.google.com/drive/folders/FOLDER_ID_HERE
#    Put that folder id in GOOGLE_DRIVE_FOLDER_ID.
#
# -----------------------------------------------------------------------------
# OPTIONAL: Workspace / service account instead (OAuth vars above EMPTY or unset).
# -----------------------------------------------------------------------------
#GOOGLE_CLIENT_EMAIL=upload-bot@proj.iam.gserviceaccount.com
#GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Same GOOGLE_DRIVE_FOLDER_ID — must share folder (Editor) with that email unless using Shared drives.

NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Max bytes per file (default 2 GB). Uploads go direct to Google Drive from the browser.
# NEXT_PUBLIC_MAX_UPLOAD_FILE_BYTES=2147483648
